@page "{id:int}"
@model JCMS.Web.Pages.Jewelry.EditModel
@{
    ViewData["Title"] = "Edit Jewelry Item";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h1 class="mb-3">Edit Jewelry Item</h1>
                <p class="text-muted">Update the item description so staff can identify it more easily during check-in and pickup.</p>

                <div asp-validation-summary="ModelOnly" class="alert alert-danger validation-summary-box" role="alert"></div>

                <form method="post">
                    <input type="hidden" asp-for="Input.Id" />
                    <input type="hidden" asp-for="Input.CustomerId" />

                    <div class="mb-3">
                        <label asp-for="Input.ItemType" class="form-label"></label>
                        <input asp-for="Input.ItemType" class="form-control" readonly />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Description" class="form-label"></label>
                        <input asp-for="Input.Description" class="form-control" />
                        <span asp-validation-for="Input.Description" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save</button>
                        <a asp-page="/Customers/Details" asp-route-id="@Model.Input.CustomerId" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}