@page "{id:int}"
@model JCMS.Web.Pages.Jewelry.EditModel
@{
    ViewData["Title"] = "Edit Jewelry Item";
}

<h1>Edit Jewelry Item</h1>

<div class="text-danger" asp-validation-summary="All"></div>

<form method="post">
    <input type="hidden" asp-for="Input.Id" />
    <input type="hidden" asp-for="Input.CustomerId" />

    <div class="mb-3">
        <label asp-for="Input.ItemType" class="form-label"></label>
        <input asp-for="Input.ItemType" class="form-control" readonly />
    </div>

    <div class="mb-3">
        <label asp-for="Input.Description" class="form-label"></label>
        <input asp-for="Input.Description" class="form-control" />
        <span asp-validation-for="Input.Description" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-page="/Customers/Details" asp-route-id="@Model.Input.CustomerId" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}