@page
@model JCMS.Web.Pages.Jewelry.CreateModel
@{
    ViewData["Title"] = "Add Jewelry Item";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h1 class="mb-2">Add Jewelry Item</h1>
                <p class="text-muted mb-4">
                    Add a jewelry item to this customer's inventory so it can be included in future cleaning orders.
                </p>

                @if (!string.IsNullOrWhiteSpace(Model.CustomerName))
                {
                    <p class="mb-3"><strong>Customer:</strong> @Model.CustomerName</p>
                }

                <div asp-validation-summary="ModelOnly" class="alert alert-danger validation-summary-box" role="alert"></div>

                <form method="post">
                    <input type="hidden" asp-for="CustomerId" />

                    <div class="mb-3">
                        <label asp-for="Input.ItemType" class="form-label">Item Type</label>
                        <select asp-for="Input.ItemType" class="form-select">
                            <option value="">-- Select type --</option>
                            <option>Ring</option>
                            <option>Necklace</option>
                            <option>Bracelet</option>
                            <option>Earrings</option>
                            <option>Charm</option>
                            <option>Anklet</option>
                            <option>Other</option>
                        </select>
                        <span asp-validation-for="Input.ItemType" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Description" class="form-label"></label>
                        <input asp-for="Input.Description" class="form-control" />
                        <div class="form-text">Enter a short description staff can recognize quickly during check-in.</div>
                        <span asp-validation-for="Input.Description" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.ParentItemId" class="form-label"></label>
                        <select asp-for="Input.ParentItemId" class="form-select">
                            <option value="">(None)</option>
                            @foreach (var b in Model.BraceletOptions)
                            {
                                <option value="@b.Id">@b.Label</option>
                            }
                        </select>
                        <div class="form-text">Only select a bracelet when the item type is Charm.</div>
                        <span asp-validation-for="Input.ParentItemId" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save</button>
                        <a asp-page="/Customers/Details" asp-route-id="@Model.CustomerId" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}