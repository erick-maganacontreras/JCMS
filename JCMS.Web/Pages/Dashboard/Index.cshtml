@page
@model JCMS.Web.Pages.Dashboard.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="mb-1">Active Orders Dashboard</h1>
        <p class="text-muted mb-0">Track the orders currently in the shop and move quickly to the next task.</p>
    </div>
    <a class="btn btn-primary" asp-page="/Customers/Index">Start New Check-In</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Active Orders</div>
                <div class="fs-3 fw-semibold">@Model.ActiveOrderCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Checked In</div>
                <div class="fs-3 fw-semibold">@Model.CheckedInCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">In Progress</div>
                <div class="fs-3 fw-semibold">@Model.InProgressCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Completed</div>
                <div class="fs-3 fw-semibold">@Model.CompletedCount</div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Active Orders</span>
        <a asp-page="/Orders/Index" class="btn btn-sm btn-outline-primary">View All Orders</a>
    </div>
    <div class="card-body p-0">
        @if (Model.ActiveOrders.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped mb-0 align-middle">
                    <thead>
                        <tr>
                            <th>Confirmation #</th>
                            <th>Customer</th>
                            <th>Status</th>
                            <th>Check-In</th>
                            <th>Items</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model.ActiveOrders)
                        {
                            <tr>
                                <td>@order.ConfirmationNumber</td>
                                <td>@order.CustomerName</td>
                                <td>@order.Status</td>
                                <td>@order.CheckInAt.ToLocalTime().ToString("g")</td>
                                <td>@order.ItemCount</td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-secondary" asp-page="/Orders/Details" asp-route-id="@order.Id">Details</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="p-4">
                <p class="mb-2">No active orders right now.</p>
                <a class="btn btn-primary" asp-page="/Customers/Index">Create the first check-in</a>
            </div>
        }
    </div>
</div>