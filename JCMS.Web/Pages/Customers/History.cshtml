@page "{id:int}"
@model JCMS.Web.Pages.Customers.HistoryModel
@{
    ViewData["Title"] = "Cleaning History";
}

@if (Model.Customer != null)
{
    <h1>Cleaning History</h1>
    <h3>@Model.Customer.FirstName @Model.Customer.LastName</h3>

    @if (!Model.History.Any())
    {
        <p>No cleaning history found for this customer.</p>
    }
    else
    {
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Confirmation #</th>
                    <th>Item Type</th>
                    <th>Description</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entry in Model.History)
                {
                    <tr>
                        <td>@entry.CleaningDate.ToLocalTime()</td>
                        <td>@entry.ConfirmationNumber</td>
                        <td>@entry.JewelryItem?.ItemType</td>
                        <td>@entry.JewelryItem?.Description</td>
                        <td>@entry.Staff?.Username</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <a asp-page="/Customers/Details" asp-route-id="@Model.Customer.Id" class="btn btn-secondary">Back to Customer</a>
}
