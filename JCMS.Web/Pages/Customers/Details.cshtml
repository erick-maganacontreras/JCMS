@page "{id:int}"
@model JCMS.Web.Pages.Customers.DetailsModel
@{
    ViewData["Title"] = "Customer Details";
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="mb-1">Customer Details</h1>
        @if (Model.Customer != null)
        {
            <p class="text-muted mb-0">@Model.Customer.FirstName @Model.Customer.LastName</p>
        }
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-success" asp-page="/Jewelry/Create" asp-route-customerId="@Model.Customer?.Id">Add Jewelry Item</a>
        <a class="btn btn-primary" asp-page="/Orders/Create" asp-route-customerId="@Model.Customer?.Id">Start Cleaning Check-In</a>
        <a class="btn btn-secondary" asp-page="/Customers/History" asp-route-id="@Model.Customer?.Id">View Cleaning History</a>
    </div>
</div>

@if (Model.Customer != null)
{
    <div class="card mb-4">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-2">Email</dt>
                <dd class="col-sm-10">@Model.Customer.Email</dd>
                <dt class="col-sm-2">Phone</dt>
                <dd class="col-sm-10">@Model.Customer.Phone</dd>
            </dl>
        </div>
    </div>
}

<h2 class="h4 mb-3">Jewelry Inventory</h2>

@if (Model.Items.Any())
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Item Type</th>
                    <th>Description</th>
                    <th>Last Cleaning</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.ItemType</td>
                        <td>@item.Description</td>
                        <td>@item.LastCleaningDate</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-secondary" asp-page="/Jewelry/Edit" asp-route-id="@item.Id">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-light border">
        <p class="mb-2">This customer does not have any jewelry items yet.</p>
        <a class="btn btn-success" asp-page="/Jewelry/Create" asp-route-customerId="@Model.Customer?.Id">Add Jewelry Item</a>
    </div>
}

<a asp-page="Index" class="btn btn-secondary mt-3">Back to Customers</a>