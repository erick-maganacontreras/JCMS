@page
@model JCMS.Web.Pages.Customers.IndexModel
@{
    ViewData["Title"] = "Customers";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="mb-1">Customers</h1>
        <p class="text-muted mb-0">Search customer records, open inventory, and begin cleaning check-in.</p>
    </div>
    <a class="btn btn-success" asp-page="Create">Create New Customer</a>
</div>

<form method="get" class="mb-3">
    <div class="input-group">
        <input asp-for="SearchTerm" class="form-control" placeholder="Search by last name, email, or phone" />
        <button type="submit" class="btn btn-primary">Search</button>
        @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
        {
            <a asp-page="Index" class="btn btn-outline-secondary">Clear</a>
        }
    </div>
</form>

@if (Model.Customers.Any())
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Last Name</th>
                    <th>First Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Customers)
                {
                    <tr>
                        <td>@c.LastName</td>
                        <td>@c.FirstName</td>
                        <td>@c.Email</td>
                        <td>@c.Phone</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-primary" asp-page="Details" asp-route-id="@c.Id">Details</a>
                            <a class="btn btn-sm btn-secondary" asp-page="Edit" asp-route-id="@c.Id">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-light border">
        @if (string.IsNullOrWhiteSpace(Model.SearchTerm))
        {
            <p class="mb-2">No customers have been added yet.</p>
        }
        else
        {
            <p class="mb-2">No customers matched your search.</p>
        }
        <a class="btn btn-success" asp-page="Create">Create New Customer</a>
    </div>
}