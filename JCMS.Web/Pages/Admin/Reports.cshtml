@page
@model JCMS.Web.Pages.Admin.ReportsModel
@{
    ViewData["Title"] = "Reports";
}

<h1>Cleaning Order Reports</h1>

<form method="get" class="mb-4">
    <div class="row g-3">
        <div class="col-md-3">
            <label asp-for="StartDate" class="form-label">Start Date</label>
            <input asp-for="StartDate" type="date" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="EndDate" class="form-label">End Date</label>
            <input asp-for="EndDate" type="date" class="form-control" />
        </div>
        <div class="col-md-3 align-self-end">
            <button type="submit" class="btn btn-primary">Generate Report</button>
        </div>
    </div>
</form>

@if (Model.Report != null)
{
    <div class="mb-3">
        <h4>Summary</h4>
        <p><strong>Total Orders:</strong> @Model.Report.TotalOrders</p>
        <p><strong>Checked In:</strong> @Model.Report.CheckedInCount</p>
        <p><strong>In Progress:</strong> @Model.Report.InProgressCount</p>
        <p><strong>Completed:</strong> @Model.Report.CompletedCount</p>
        <p><strong>Picked Up:</strong> @Model.Report.PickedUpCount</p>
        <p><strong>Cancelled:</strong> @Model.Report.CancelledCount</p>
    </div>

    <form method="post" asp-page-handler="ExportCsv" class="mb-3">
        <input type="hidden" name="startDate" value="@Model.StartDate?.ToString("yyyy-MM-dd")" />
        <input type="hidden" name="endDate" value="@Model.EndDate?.ToString("yyyy-MM-dd")" />
        <button type="submit" class="btn btn-success">Export CSV</button>
    </form>

    @if (!Model.Report.Orders.Any())
    {
        <p>No orders found for the selected date range.</p>
    }
    else
    {
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>Confirmation #</th>
                    <th>Customer</th>
                    <th>Status</th>
                    <th>Check-In Date</th>
                    <th>Completion Date</th>
                    <th>Item Count</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model.Report.Orders)
                {
                    <tr>
                        <td>@order.ConfirmationNumber</td>
                        <td>@order.Customer.FirstName @order.Customer.LastName</td>
                        <td>@order.Status</td>
                        <td>@order.CheckInAt.ToLocalTime()</td>
                        <td>@(order.CompletedAt.HasValue? order.CompletedAt.Value.ToLocalTime().ToString() : "")</td>
                        <td>@order.OrderItems.Count</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}