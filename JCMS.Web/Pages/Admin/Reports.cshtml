@page
@model JCMS.Web.Pages.Admin.ReportsModel
@{
    ViewData["Title"] = "Reports";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="mb-1">Cleaning Order Reports</h1>
        <p class="text-muted mb-0">Review order activity by date range and export the results to a CSV file.</p>
    </div>
</div>

<div asp-validation-summary="ModelOnly" class="alert alert-danger validation-summary-box" role="alert"></div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="get">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label asp-for="StartDate" class="form-label">Start Date</label>
                    <input asp-for="StartDate" type="date" class="form-control" />
                    <span asp-validation-for="StartDate" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="EndDate" class="form-label">End Date</label>
                    <input asp-for="EndDate" type="date" class="form-control" />
                    <span asp-validation-for="EndDate" class="text-danger"></span>
                </div>
                <div class="col-md-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Generate Report</button>
                    <a asp-page="Reports" class="btn btn-outline-secondary">Clear</a>
                </div>
            </div>
        </form>
    </div>
</div>

@if (Model.Report != null)
{
    <div class="row g-3 mb-4">
        <div class="col-md-2">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Total Orders</div>
                    <div class="fs-4 fw-semibold">@Model.Report.TotalOrders</div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Checked In</div>
                    <div class="fs-4 fw-semibold">@Model.Report.CheckedInCount</div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">In Progress</div>
                    <div class="fs-4 fw-semibold">@Model.Report.InProgressCount</div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Completed</div>
                    <div class="fs-4 fw-semibold">@Model.Report.CompletedCount</div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Picked Up</div>
                    <div class="fs-4 fw-semibold">@Model.Report.PickedUpCount</div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Cancelled</div>
                    <div class="fs-4 fw-semibold">@Model.Report.CancelledCount</div>
                </div>
            </div>
        </div>
    </div>

    <form method="post" asp-page-handler="ExportCsv" class="mb-3">
        <input type="hidden" name="startDate" value="@Model.StartDate?.ToString("yyyy-MM-dd")" />
        <input type="hidden" name="endDate" value="@Model.EndDate?.ToString("yyyy-MM-dd")" />
        <button type="submit" class="btn btn-success">Export CSV</button>
    </form>

    @if (!Model.Report.Orders.Any())
    {
        <div class="alert alert-light border">
            No orders were found for the selected date range.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-bordered align-middle">
                <thead>
                    <tr>
                        <th>Confirmation #</th>
                        <th>Customer</th>
                        <th>Status</th>
                        <th>Check-In Date</th>
                        <th>Completion Date</th>
                        <th>Item Count</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.Report.Orders)
                    {
                        <tr>
                            <td>@order.ConfirmationNumber</td>
                            <td>@order.Customer.FirstName @order.Customer.LastName</td>
                            <td>@order.Status</td>
                            <td>@order.CheckInAt.ToLocalTime().ToString("g")</td>
                            <td>@(order.CompletedAt.HasValue? order.CompletedAt.Value.ToLocalTime().ToString("g") : "Not completed")</td>
                            <td>@order.OrderItems.Count</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}