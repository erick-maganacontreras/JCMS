<div class="card">
    <div class="card-body">
        @if (Model.StaffUsers.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Username</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.StaffUsers)
                        {
                            <tr>
                                <td>@user.Username</td>
                                <td>@user.Role</td>
                                <td>
                                    @if (user.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-2">
                                        @if (user.IsActive)
                                        {
                                            <form method="post" asp-page-handler="Deactivate" asp-route-id="@user.Id" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-warning"
                                                        onclick="return confirm('Deactivate this user?');">
                                                    Deactivate
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form method="post" asp-page-handler="Activate" asp-route-id="@user.Id" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-success">
                                                    Activate
                                                </button>
                                            </form>
                                        }

                                        <form method="post" asp-page-handler="Delete" asp-route-id="@user.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('Delete this user? This action cannot be undone.');">
                                                Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="mb-0">No users found.</p>
        }
    </div>
</div>