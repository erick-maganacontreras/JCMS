@page
@model JCMS.Web.Pages.Orders.IndexModel
@{
    ViewData["Title"] = "Orders";
}

<h1>Active Cleaning Orders</h1>

@if (!Model.Orders.Any())
{
    <p>No active cleaning orders were found.</p>
}
else
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Confirmation #</th>
                <th>Customer</th>
                <th>Status</th>
                <th>Checked In</th>
                <th>Item Count</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model.Orders)
            {
                <tr>
                    <td>@order.ConfirmationNumber</td>
                    <td>@order.Customer.FirstName @order.Customer.LastName</td>
                    <td>@order.Status</td>
                    <td>@order.CheckInAt.ToLocalTime()</td>
                    <td>@order.OrderItems.Count</td>
                    <td>
                        <a class="btn btn-sm btn-primary" asp-page="/Orders/Details" asp-route-id="@order.Id">View</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}