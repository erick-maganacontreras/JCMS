@page
@model JCMS.Web.Pages.Orders.IndexModel
@{
    ViewData["Title"] = "Orders";
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="mb-1">Active Cleaning Orders</h1>
        <p class="text-muted mb-0">Search orders by customer or filter them by status.</p>
    </div>
    <a class="btn btn-primary" asp-page="/Customers/Index">Start New Check-In</a>
</div>

<form method="get" class="mb-4">
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="SearchTerm" class="form-label">Search</label>
            <input asp-for="SearchTerm" class="form-control" placeholder="Confirmation number, first name, or last name" />
        </div>
        <div class="col-md-4">
            <label asp-for="Status" class="form-label">Status</label>
            <select asp-for="Status" asp-items="Model.StatusOptions" class="form-select"></select>
        </div>
        <div class="col-md-2 d-flex align-items-end gap-2">
            <button type="submit" class="btn btn-primary w-100">Filter</button>
        </div>
    </div>
</form>

@if (!Model.Orders.Any())
{
    <div class="alert alert-light border">
        No cleaning orders were found.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle">
            <thead>
                <tr>
                    <th>Confirmation #</th>
                    <th>Customer</th>
                    <th>Status</th>
                    <th>Checked In</th>
                    <th>Item Count</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model.Orders)
                {
                    <tr>
                        <td>@order.ConfirmationNumber</td>
                        <td>@order.Customer.FirstName @order.Customer.LastName</td>
                        <td>@order.Status</td>
                        <td>@order.CheckInAt.ToLocalTime().ToString("g")</td>
                        <td>@order.OrderItems.Count</td>
                        <td>
                            <a class="btn btn-sm btn-primary" asp-page="/Orders/Details" asp-route-id="@order.Id">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}