@page "{id:int}"
@model JCMS.Web.Pages.Orders.DetailsModel
@{
    ViewData["Title"] = "Order Details";
}

@if (Model.Order != null)
{
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
        <div>
            <h1 class="mb-1">Order Details</h1>
            <p class="text-muted mb-0">Confirmation number @Model.Order.ConfirmationNumber</p>
        </div>
        <a asp-page="/Orders/Index" class="btn btn-secondary">Back to Orders</a>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Customer</dt>
                <dd class="col-sm-9">@Model.Order.Customer.FirstName @Model.Order.Customer.LastName</dd>

                <dt class="col-sm-3">Created By</dt>
                <dd class="col-sm-9">@Model.Order.Staff.Username (@Model.Order.Staff.Role)</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@Model.Order.Status</dd>

                <dt class="col-sm-3">Checked In</dt>
                <dd class="col-sm-9">@Model.Order.CheckInAt.ToLocalTime().ToString("g")</dd>

                @if (Model.Order.CompletedAt != null)
                {
                    <dt class="col-sm-3">Completed</dt>
                    <dd class="col-sm-9">@Model.Order.CompletedAt.Value.ToLocalTime().ToString("g")</dd>
                }

                @if (Model.Order.PickedUpAt != null)
                {
                    <dt class="col-sm-3">Picked Up</dt>
                    <dd class="col-sm-9">@Model.Order.PickedUpAt.Value.ToLocalTime().ToString("g")</dd>
                }
            </dl>
        </div>
    </div>

    <h2 class="h4 mb-3">Items</h2>

    <div class="table-responsive mb-4">
        <table class="table table-bordered align-middle">
            <thead>
                <tr>
                    <th>Item Type</th>
                    <th>Description</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Order.OrderItems)
                {
                    <tr>
                        <td>@item.JewelryItem.ItemType</td>
                        <td>@item.JewelryItem.Description</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card">
        <div class="card-body">
            <h2 class="h4 mb-3">Update Status</h2>

            <div asp-validation-summary="ModelOnly" class="alert alert-danger validation-summary-box" role="alert"></div>

            <form method="post" asp-page-handler="UpdateStatus">
                <div class="mb-3">
                    <label asp-for="NewStatus" class="form-label">New Status</label>
                    <select asp-for="NewStatus" asp-items="Model.StatusOptions" class="form-select"></select>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Save Status</button>
                    <a asp-page="/Orders/Index" class="btn btn-secondary">Back to Orders</a>
                </div>
            </form>
        </div>
    </div>
}